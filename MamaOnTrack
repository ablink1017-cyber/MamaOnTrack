 </div>
 )}

{/* Action buttons */}

 <div style={{ display:"flex", gap:10 }}>
 {totalSecs > 0 && (
 <button
 onClick={handleSave}
 style={{ flex:1, padding:"12px", borderRadius:999, background:`linear-gradient(135deg,${th.accent},${th.purple})`, color:"#fff", border:"none", cursor:"pointer", fontWeight:500, fontSize:14, boxShadow:`0 3px 12px ${th.accent}44` }}>
 Save Session ({totalMins} min)
